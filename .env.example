# Backend API origin (no trailing slash). Point this at your deployed backend,
# e.g. https://bossai-production.up.railway.app — leave unset for local dev
# against http://localhost:8080.
VITE_API_BASE=http://localhost:8080

# EmailJS — beta waitlist signup form
# Create free account at https://emailjs.com
# 1. Add Email Service (Gmail / Outlook) → copy Service ID
# 2. Create Email Template → copy Template ID
#    Template variables used: {{name}}, {{email}}
# 3. Account → API Keys → copy Public Key
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx
