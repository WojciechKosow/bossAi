{
  "id": "PROBLEM_PAYOFF",
  "display_name": "Problem → Payoff",
  "pacing": "FAST",

  "color_grade": {
    "preset": "problem_payoff",
    "contrast_boost": 1.3,
    "saturation": 0.7,
    "brightness": 0.95,
    "vignette": 0.2
  },

  "beats": {
    "A": {
      "name": "HOOK / BÓL",
      "start_ms": 0,
      "end_ms": 3000,
      "min_duration_ms": 1200,
      "max_duration_ms": 2000,
      "color_grade_override": {
        "saturation": 0.6,
        "contrast_boost": 1.4,
        "brightness": 0.95,
        "vignette": 0.25
      },
      "grammar": {
        "restraint_weight": 0.2,
        "effects": [
          {
            "type": "smash_zoom",
            "weight": 2.0,
            "intensity_range": [0.85, 1.0],
            "max_per_beat": 1,
            "params": { "scale_from": 1.0, "scale_to": 2.2, "easing": "easeOut", "duration_ms": 90 },
            "prefers": { "segment_types": ["hook", "climax"], "min_energy": 0.4 }
          },
          {
            "type": "shake",
            "weight": 1.2,
            "intensity_range": [0.6, 0.9],
            "params": { "amplitude": 10, "frequency": 20 },
            "prefers": { "on_beat": true, "min_music_energy": 0.5 }
          },
          {
            "type": "fast_zoom",
            "weight": 1.0,
            "intensity_range": [0.7, 1.0],
            "params": { "scale_from": 1.0, "scale_to": 1.6, "easing": "easeOut", "duration_ms": 150 },
            "prefers": { "min_energy": 0.35 }
          }
        ],
        "transitions": [
          {
            "type": "cut",
            "weight": 2.0,
            "duration_ms": 0,
            "prefers": { "classifications": ["HARD", "MICRO"] }
          },
          { "type": "fade", "weight": 0.3, "duration_ms": 150 }
        ]
      }
    },

    "B": {
      "name": "ESKALACJA PROBLEMU",
      "start_ms": 3000,
      "end_ms": 8000,
      "min_duration_ms": 1500,
      "max_duration_ms": 2500,
      "color_grade_override": {
        "saturation": 0.65,
        "contrast_boost": 1.35,
        "brightness": 0.9,
        "vignette": 0.2
      },
      "grammar": {
        "restraint_weight": 0.8,
        "effects": [
          {
            "type": "zoom_in_offset",
            "weight": 1.5,
            "intensity_range": [0.6, 0.9],
            "params": { "scale_from": 1.0, "scale_to": 1.3, "offset_x": 0.3, "offset_y": 0.4, "easing": "easeOut" },
            "prefers": { "segment_types": ["emphasis", "point"], "min_importance": 0.5 }
          },
          {
            "type": "pan_left",
            "weight": 1.0,
            "intensity_range": [0.5, 0.75],
            "params": { "direction": "left", "distance_percent": 13, "easing": "linear" },
            "prefers": { "segment_types": ["point", "setup"], "max_energy": 0.75 }
          },
          {
            "type": "pan_right",
            "weight": 1.0,
            "intensity_range": [0.5, 0.75],
            "params": { "direction": "right", "distance_percent": 13, "easing": "linear" },
            "prefers": { "segment_types": ["point", "setup"], "max_energy": 0.75 }
          },
          {
            "type": "zoom_in",
            "weight": 0.8,
            "intensity_range": [0.5, 0.8],
            "params": { "scale_from": 1.0, "scale_to": 1.25, "easing": "easeInOut" },
            "prefers": { "segment_types": ["setup"] }
          }
        ],
        "transitions": [
          {
            "type": "cut",
            "weight": 1.5,
            "duration_ms": 0,
            "prefers": { "classifications": ["HARD", "MICRO"] }
          },
          { "type": "fade", "weight": 0.6, "duration_ms": 150 }
        ]
      }
    },

    "C": {
      "name": "NAPIĘCIE / SYNC",
      "start_ms": 8000,
      "end_ms": 15000,
      "min_duration_ms": 1200,
      "max_duration_ms": 2500,
      "color_grade_override": {
        "saturation": 0.75,
        "contrast_boost": 1.25,
        "brightness": 0.95,
        "vignette": 0.15
      },
      "grammar": {
        "restraint_weight": 1.0,
        "effects": [
          {
            "type": "blur_transition",
            "weight": 1.2,
            "intensity_range": [0.5, 0.8],
            "params": { "blur_amount": 18, "duration_ms": 200, "phase": "outro" },
            "prefers": { "segment_types": ["transition", "cooldown"] }
          },
          {
            "type": "zoom_in",
            "weight": 1.0,
            "intensity_range": [0.5, 0.75],
            "params": { "scale_from": 1.0, "scale_to": 1.25, "easing": "easeInOut" },
            "prefers": { "segment_types": ["setup", "point"] }
          },
          {
            "type": "zoom_pulse",
            "weight": 0.8,
            "intensity_range": [0.5, 0.8],
            "params": { "scale": 1.08, "frequency_bpm": 120 },
            "prefers": { "on_beat": true, "min_music_energy": 0.55 }
          }
        ],
        "transitions": [
          {
            "type": "fade",
            "weight": 1.2,
            "duration_ms": 150,
            "prefers": { "classifications": ["SOFT"] }
          },
          {
            "type": "cut",
            "weight": 1.0,
            "duration_ms": 0,
            "prefers": { "classifications": ["HARD", "MICRO"] }
          }
        ]
      }
    },

    "D": {
      "name": "REVEAL / PRODUKT",
      "start_ms": 15000,
      "end_ms": 22000,
      "min_duration_ms": 2500,
      "max_duration_ms": 4000,
      "color_grade_override": {
        "saturation": 1.1,
        "contrast_boost": 1.15,
        "brightness": 1.02,
        "vignette": 0.1
      },
      "grammar": {
        "restraint_weight": 0.9,
        "effects": [
          {
            "type": "brightness_burst",
            "weight": 1.6,
            "intensity_range": [0.7, 0.95],
            "max_per_beat": 1,
            "params": { "brightness_delta": 0.45, "duration_ms": 120, "easing": "easeOut" },
            "prefers": { "segment_types": ["climax", "emphasis"], "min_importance": 0.6 }
          },
          {
            "type": "ken_burns",
            "weight": 1.2,
            "intensity_range": [0.4, 0.6],
            "params": { "scale_from": 1.0, "scale_to": 1.25, "pan_direction": "left" },
            "prefers": { "asset_kinds": ["IMAGE"] }
          },
          {
            "type": "color_pop",
            "weight": 1.0,
            "intensity_range": [0.6, 0.9],
            "params": { "saturation_boost": 0.35, "duration_ms": 200, "easing": "easeOut" },
            "prefers": { "segment_types": ["climax", "emphasis"] }
          },
          {
            "type": "zoom_in",
            "weight": 0.8,
            "intensity_range": [0.5, 0.75],
            "params": { "scale_from": 1.0, "scale_to": 1.2, "easing": "easeOut" }
          }
        ],
        "transitions": [
          {
            "type": "fade_white",
            "weight": 1.2,
            "duration_ms": 120,
            "prefers": { "segment_types": ["climax"] }
          },
          { "type": "fade", "weight": 1.0, "duration_ms": 180 },
          {
            "type": "cut",
            "weight": 0.6,
            "duration_ms": 0,
            "prefers": { "classifications": ["HARD", "MICRO"] }
          }
        ]
      }
    },

    "E": {
      "name": "TRANSFORMACJA",
      "start_ms": 22000,
      "end_ms": 27000,
      "min_duration_ms": 2500,
      "max_duration_ms": 3500,
      "color_grade_override": {
        "saturation": 1.2,
        "contrast_boost": 1.2,
        "brightness": 1.05,
        "vignette": 0.05
      },
      "grammar": {
        "restraint_weight": 1.0,
        "effects": [
          {
            "type": "color_pop",
            "weight": 1.5,
            "intensity_range": [0.65, 0.9],
            "params": { "saturation_boost": 0.35, "duration_ms": 200, "easing": "easeOut" },
            "prefers": { "segment_types": ["emphasis", "climax"], "min_energy": 0.45 }
          },
          {
            "type": "zoom_in",
            "weight": 1.0,
            "intensity_range": [0.55, 0.8],
            "params": { "scale_from": 1.0, "scale_to": 1.2, "easing": "easeOut" }
          },
          {
            "type": "ken_burns",
            "weight": 0.7,
            "intensity_range": [0.4, 0.6],
            "params": { "scale_from": 1.0, "scale_to": 1.2, "pan_direction": "right" },
            "prefers": { "asset_kinds": ["IMAGE"] }
          }
        ],
        "transitions": [
          { "type": "fade", "weight": 1.2, "duration_ms": 180 },
          {
            "type": "wipe_right",
            "weight": 0.6,
            "duration_ms": 200,
            "prefers": { "classifications": ["HARD"] }
          },
          {
            "type": "cut",
            "weight": 0.8,
            "duration_ms": 0,
            "prefers": { "classifications": ["MICRO"] }
          }
        ]
      }
    },

    "F": {
      "name": "CTA",
      "start_ms": 27000,
      "end_ms": 30000,
      "min_duration_ms": 2500,
      "max_duration_ms": 3000,
      "color_grade_override": {
        "saturation": 1.1,
        "contrast_boost": 1.1,
        "brightness": 1.0,
        "vignette": 0.05
      },
      "grammar": {
        "restraint_weight": 1.2,
        "effects": [
          {
            "type": "ken_burns",
            "weight": 1.5,
            "intensity_range": [0.3, 0.5],
            "params": { "scale_from": 1.0, "scale_to": 1.1, "pan_direction": "right" },
            "prefers": { "segment_types": ["cta"] }
          },
          {
            "type": "zoom_in",
            "weight": 0.8,
            "intensity_range": [0.4, 0.6],
            "params": { "scale_from": 1.0, "scale_to": 1.15, "easing": "easeInOut" }
          }
        ],
        "transitions": [
          { "type": "fade", "weight": 1.5, "duration_ms": 400 }
        ]
      }
    }
  },

  "subtitle_config": {
    "enabled": true,
    "position": "bottom_third",
    "font_family": "Inter",
    "font_size": 44,
    "font_weight": "bold",
    "highlight_color": "#FFD700",
    "stroke_color": "#000000",
    "stroke_width": 3,
    "highlight_mode": "word",
    "max_words_per_group": 3,
    "animation": "karaoke"
  },

  "audio_config": {
    "voiceover_volume": 1.0,
    "voiceover_fade_out_ms": 300,
    "volume_by_beat": {
      "A": 0.06,
      "B": 0.09,
      "C": 0.11,
      "D": 0.14,
      "E": 0.18,
      "F": 0.22
    },
    "energy_modulation": 0.25,
    "ramp_ms": 250,
    "music_fade_in_ms": 300,
    "music_fade_out_ms": 600,
    "music_style": "energetic_upbeat"
  },

  "composition_rules": {
    "enabled": true,
    "max_layered_scenes_pct": 40,
    "rules": {
      "TalkingHeadBg": {
        "enabled": true,
        "applicable_beats": ["B", "C", "E"],
        "composition": "pip",
        "background_opacity": 0.65,
        "background_blur": true,
        "primary_scale": 0.85,
        "primary_position": "center"
      },
      "ProductReveal": {
        "enabled": true,
        "applicable_beats": ["D", "E"],
        "composition": "overlay",
        "overlay_scale": 0.45,
        "overlay_position": "center",
        "overlay_opacity": 1.0,
        "trigger_segment_types": ["climax", "emphasis"]
      },
      "CtaOverlay": {
        "enabled": true,
        "applicable_beats": ["F"],
        "composition": "overlay",
        "overlay_scale": 0.6,
        "overlay_position": "bottom_center",
        "overlay_opacity": 1.0,
        "trigger_segment_types": ["cta"]
      }
    }
  },

  "text_overlay_templates": [
    {
      "beat": "A",
      "placeholder": "{HOOK_TEXT}",
      "type": "TEXT_OVERLAY",
      "start_ms": 0,
      "end_ms": 2500,
      "layer": 2,
      "position": "center",
      "animation": "bounce",
      "animation_duration_ms": 100,
      "style": {
        "font_family": "Inter",
        "font_size": 58,
        "font_weight": "bold",
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width": 4,
        "background_color": null,
        "background_padding": 0,
        "border_radius": null
      }
    },
    {
      "beat": "E",
      "placeholder": "{RESULT_TEXT}",
      "type": "TEXT_OVERLAY",
      "start_ms": 22000,
      "end_ms": 27000,
      "layer": 2,
      "position": "bottom_third",
      "animation": "slide_up",
      "animation_duration_ms": 250,
      "style": {
        "font_family": "Inter",
        "font_size": 52,
        "font_weight": "bold",
        "color": "#FFD700",
        "stroke_color": "#000000",
        "stroke_width": 3,
        "background_color": null,
        "background_padding": 0,
        "border_radius": null
      }
    },
    {
      "beat": "F",
      "placeholder": "{CTA_TEXT}",
      "type": "TEXT_OVERLAY",
      "start_ms": 27000,
      "end_ms": 30000,
      "layer": 2,
      "position": "bottom_quarter",
      "animation": "fade_in",
      "animation_duration_ms": 200,
      "style": {
        "font_family": "Inter",
        "font_size": 46,
        "font_weight": "bold",
        "color": "#FFFFFF",
        "stroke_color": null,
        "stroke_width": 0,
        "background_color": "#E63946",
        "background_padding": 20,
        "border_radius": 8
      }
    }
  ]
}
