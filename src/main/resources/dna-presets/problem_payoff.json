  },

  "subtitle_config": {
    "enabled": true,
    "position": "bottom_third",
    "font_family": "Inter",
    "font_size": 44,
    "font_weight": "bold",
    "highlight_color": "#FFD700",
    "stroke_color": "#000000",
    "stroke_width": 3,
    "highlight_mode": "word",
    "max_words_per_group": 3,
    "animation": "karaoke"
  },

  "audio_config": {
    "voiceover_volume": 1.0,
    "voiceover_fade_out_ms": 300,
    "volume_by_beat": {
      "A": 0.06,
      "B": 0.09,
      "C": 0.11,
      "D": 0.14,
      "E": 0.18,
      "F": 0.22
    },
    "music_fade_in_ms": 300,
    "music_fade_out_ms": 600,
    "music_style": "energetic_upbeat"
  },

  "composition_rules": {
    "enabled": true,
    "max_layered_scenes_pct": 40,
    "rules": {
      "TalkingHeadBg": {
        "enabled": true,
        "applicable_beats": ["B", "C", "E"],
        "composition": "pip",
        "background_opacity": 0.65,
        "background_blur": true,
        "primary_scale": 0.85,
        "primary_position": "center"
      },
      "ProductReveal": {
        "enabled": true,
        "applicable_beats": ["D", "E"],
        "composition": "overlay",
        "overlay_scale": 0.45,
        "overlay_position": "center",
        "overlay_opacity": 1.0,
        "trigger_segment_types": ["climax", "emphasis"]
      },
      "CtaOverlay": {
        "enabled": true,
        "applicable_beats": ["F"],
        "composition": "overlay",
        "overlay_scale": 0.6,
        "overlay_position": "bottom_center",
        "overlay_opacity": 1.0,
        "trigger_segment_types": ["cta"]
      }
    }
  },

  "text_overlay_templates": [
    {
      "beat": "A",
      "placeholder": "{HOOK_TEXT}",
      "type": "TEXT_OVERLAY",
      "start_ms": 0,
      "end_ms": 2500,
      "layer": 2,
      "position": "center",
      "animation": "bounce",
      "animation_duration_ms": 100,
      "style": {
        "font_family": "Inter",
        "font_size": 58,
        "font_weight": "bold",
        "color": "#FFFFFF",
        "stroke_color": "#000000",
        "stroke_width": 4,
        "background_color": null,
        "background_padding": 0,
        "border_radius": null
      }
    },
    {
      "beat": "E",
      "placeholder": "{RESULT_TEXT}",
      "type": "TEXT_OVERLAY",
      "start_ms": 22000,
      "end_ms": 27000,
      "layer": 2,
      "position": "bottom_third",
      "animation": "slide_up",
      "animation_duration_ms": 250,
      "style": {
        "font_family": "Inter",
        "font_size": 52,
        "font_weight": "bold",
        "color": "#FFD700",
        "stroke_color": "#000000",
        "stroke_width": 3,
        "background_color": null,
        "background_padding": 0,
        "border_radius": null
      }
    },
    {
      "beat": "F",
      "placeholder": "{CTA_TEXT}",
      "type": "TEXT_OVERLAY",
      "start_ms": 27000,
      "end_ms": 30000,
      "layer": 2,
      "position": "bottom_quarter",
      "animation": "fade_in",
      "animation_duration_ms": 200,
      "style": {
        "font_family": "Inter",
        "font_size": 46,
        "font_weight": "bold",
        "color": "#FFFFFF",
        "stroke_color": null,
        "stroke_width": 0,
        "background_color": "#E63946",
        "background_padding": 20,
        "border_radius": 8
      }
