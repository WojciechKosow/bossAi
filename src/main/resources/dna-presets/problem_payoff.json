          "transition": {
            "type": "cut",
            "duration_ms": 0
          },
          "color_grade_override": {
            "saturation": 0.6,
            "contrast_boost": 1.4,
            "brightness": 0.95,
            "vignette": 0.25
          }
        },
        {
          "effect": {
            "type": "shake",
            "intensity": 0.8,
